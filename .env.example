# Environment Variables for Kizlly
# Copy this file to .env and fill in your values

# Groq API (for LLaMA 3.3 70B inference)
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Neo4j AuraDB (free tier)
# Create instance at: https://console.neo4j.io
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# JWT Authentication Secret (auto-generated in production)
JWT_SECRET=change-this-to-a-random-secret-in-production

# Optional: Override defaults
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# CHUNK_SIZE=512
# CHUNK_OVERLAP=100
# PORT=8000
# DEBUG=false
# ALLOWED_ORIGINS=https://kizlly.render.com
# ENFORCE_HTTPS=true
